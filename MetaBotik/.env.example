YANDEX_API_KEY=your-yandex-api-key-here
YANDEX_FOLDER_ID=b1g-your-folder-id-here

# Pick a Yandex AI Studio model URI. Either pass a slug
#   YANDEX_MODEL=qwen3-235b-a22b-fp8/latest
# or the gallery display name and the validator will normalise it
#   YANDEX_MODEL=Qwen3-235B-A22B-Instruct-2507-FP8
YANDEX_MODEL=yandexgpt/latest

# Optional secondary model used only by the baseline-two-stage packager step
# YANDEX_MODEL_BASELINE_PACKAGER=

# OpenAI-compatible endpoint (default works for Yandex AI Studio)
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

# LLM behaviour
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=15000
LLM_TIMEOUT_SECONDS=300.0
LLM_REQUEST_SLEEP_SECONDS=1.0
LLM_SAVE_RAW_RESPONSES=true
LLM_SKIP_EXISTING=true
